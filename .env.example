# Django Settings
# Copy this file to .env and fill in your values

# Secret key - Generate one at: python generate_secret_key.py
# For production, use a unique key for each environment
SECRET_KEY=your-secret-key-here

# Debug mode - ALWAYS set to False in production
# Set to True only for local development
DEBUG=True

# Allowed hosts - Comma-separated list of domains
# For local dev: localhost,127.0.0.1
# For production: yourdomain.com,www.yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# For SQLite (development): leave these as default
# For PostgreSQL (production): fill in your details

# Database engine - use one of:
# - django.db.backends.sqlite3 (default, development)
# - django.db.backends.postgresql (production)
DB_ENGINE=django.db.backends.sqlite3

# Database name
# SQLite: path to database file (default: db.sqlite3)
# PostgreSQL: database name
DB_NAME=db.sqlite3

# Database user (postgresql only)
DB_USER=

# Database password (postgresql only)
DB_PASSWORD=

# Database host (postgresql only)
# Example: dpg-xxxxx.render.com
DB_HOST=

# Database port (postgresql only)
DB_PORT=

# Email Configuration (Optional)
# Leave blank to use console email backend (prints to console)

# Email backend - use one of:
# - django.core.mail.backends.console.EmailBackend (development, prints to console)
# - django.core.mail.backends.smtp.EmailBackend (production)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# SMTP server
EMAIL_HOST=smtp.gmail.com

# SMTP port (usually 587 for TLS)
EMAIL_PORT=587

# Use TLS encryption
EMAIL_USE_TLS=True

# SMTP username (email address)
EMAIL_HOST_USER=your-email@gmail.com

# SMTP password (or app-specific password for Gmail)
EMAIL_HOST_PASSWORD=

# Application Settings
# Timezone for the application
TIME_ZONE=Asia/Kolkata

# Language code
LANGUAGE_CODE=en-us

# Security Settings
# These are automatically configured based on DEBUG setting
# In production (DEBUG=False), HTTPS and secure cookies are enforced
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
